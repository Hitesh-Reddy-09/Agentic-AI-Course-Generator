APP_NAME=AI Course Generator API
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

POSTGRES_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_course_gen
CHECKPOINTER_DB_URI=postgresql://postgres:postgres@localhost:5432/ai_course_gen

CHROMA_PERSIST_DIRECTORY=./.chroma
CHROMA_COLLECTION_PREFIX=ai-course
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

GROQ_API_KEY=replace_with_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

YOUTUBE_API_KEY=replace_with_youtube_key
YOUTUBE_API_ENABLED=true
MAX_YOUTUBE_RESULTS=3
YOUTUBE_MAX_CALLS_PER_PROCESS=20

TRANSCRIPT_FALLBACK_ENABLED=true
ENABLE_CERTIFICATE_PDF=false
